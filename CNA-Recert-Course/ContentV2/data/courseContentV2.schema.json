{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CNA Recertification ContentV2 Schema",
  "type": "object",
  "required": [
    "generated_at",
    "project",
    "modules",
    "assessments",
    "clinical_support",
    "source_manifest"
  ],
  "properties": {
    "generated_at": {
      "type": "string"
    },
    "project": {
      "type": "string"
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "module_id",
          "module_title",
          "estimated_minutes",
          "lessons",
          "instructional_minutes",
          "counts_toward_720_instructional_minutes",
          "assessment_minutes_excluded_from_instructional_total",
          "source_time_basis",
          "time_model_status"
        ]
      }
    },
    "assessments": {
      "type": "object"
    },
    "clinical_support": {
      "type": "object"
    },
    "source_manifest": {
      "type": "array"
    },
    "time_model": {
      "$ref": "#/$defs/timeModel"
    }
  },
  "$defs": {
    "timeModelFields": {
      "type": "object",
      "description": "Explicit time-model fields. Instructional minutes are inherited from the ContentV1 syllabus allocation and are NOT recomputed from narration length or card count. Narration, reading/review, interaction, and assessment minutes are tracked separately and never replace the instructional allocation.",
      "properties": {
        "instructional_minutes": { "type": "number", "description": "Required theory allocation inherited from ContentV1 syllabus." },
        "estimated_active_learning_minutes": { "type": "number" },
        "estimated_narration_minutes": { "type": "number", "description": "Descriptive narration estimate; never treated as full lesson/module time." },
        "estimated_reading_minutes": { "type": "number" },
        "estimated_interaction_minutes": { "type": "number" },
        "estimated_assessment_minutes": { "type": "number", "description": "Assessment time tracked separately; excluded from the 720 instructional total." },
        "assessment_minutes_excluded_from_instructional_total": { "type": "boolean" },
        "counts_toward_720_instructional_minutes": { "type": "boolean" },
        "counts_toward_certificate_gate": { "type": "boolean" },
        "counts_toward_optional_clinical_support": { "type": "boolean" },
        "source_time_basis": { "type": "string" },
        "time_model_status": { "type": "string" },
        "time_model_notes": { "type": "string" }
      }
    },
    "timeModel": {
      "type": "object",
      "description": "Top-level required-theory time model. The 720 total is authoritative from the ContentV1 syllabus; optional clinical support and assessment time are excluded.",
      "required": [
        "required_theory_instructional_minutes_total",
        "module_allocation",
        "optional_clinical_support_counts_toward_720"
      ],
      "properties": {
        "source_basis": { "type": "string" },
        "required_theory_instructional_minutes_total": { "type": "number", "const": 720 },
        "required_theory_hours": { "type": "number" },
        "module_allocation": { "type": "object", "additionalProperties": { "type": "number" } },
        "module_assessment_minutes_excluded": { "type": "number" },
        "course_final_assessment_minutes_excluded": { "type": "number" },
        "optional_clinical_support_counts_toward_720": { "type": "boolean", "const": false },
        "rules": { "type": "array", "items": { "type": "string" } }
      }
    },
    "mediaPromptPlaceholder": {
      "type": "object",
      "description": "Per-card media readiness slot. No assets are generated for the MVP; a safe 16:9 placeholder with alt text is always available.",
      "properties": {
        "app_location": { "type": "string" },
        "scene_title": { "type": "string" },
        "image_16_9_prompt": { "type": "string" },
        "optional_video_prompt": { "type": "string" },
        "negative_prompt": { "type": "string" },
        "alt_text": { "type": "string" },
        "media_status": { "type": "string", "enum": ["asset-ready", "placeholder-pending"] },
        "asset_path": { "type": "string" },
        "required_for_mvp": { "type": "boolean" },
        "phi_safety_note": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "remediation": {
      "type": "object",
      "description": "Course-extension remediation for a lesson challenge debrief card. Never exposes final-exam answer keys or internal scoring language to learners.",
      "properties": {
        "remediation_model": { "type": "string", "const": "course_extension" },
        "safety_principle": { "type": "string" },
        "safest_response": {
          "type": "object",
          "properties": {
            "option_id": { "type": "string", "description": "Internal-only; never rendered as an answer key." },
            "text": { "type": "string" }
          }
        },
        "selected_response": { "type": ["string", "null"], "description": "Runtime learner selection; null in canonical data." },
        "why_correct": { "type": "string" },
        "why_incorrect": { "type": "object", "additionalProperties": { "type": "string" } },
        "option_rationales": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "status": { "type": "string", "enum": ["safest", "needs-review"] },
              "why": { "type": "string" },
              "remember": { "type": "string" }
            }
          }
        },
        "resident_safety_note": { "type": "string" },
        "cna_scope_note": { "type": "string" },
        "remember_this": { "type": "string" },
        "remediation_narration": { "type": "string" },
        "remediation_transcript": { "type": "string" },
        "remediation_media_prompt": { "$ref": "#/$defs/mediaPromptPlaceholder" },
        "remediation_completion_condition": { "type": "string" }
      }
    }
  }
}